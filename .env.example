# Environment Configuration Example
# Copy this file to .env and fill in actual values

# Database
DATABASE_URL=postgresql+asyncpg://sentinel:YOUR_PASSWORD@postgres:5432/sentinelai
VECTORDB_URL=postgresql+asyncpg://vectoradmin:YOUR_PASSWORD@vectordb:5432/vectordb

# Redis
REDIS_URL=redis://:YOUR_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:YOUR_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:YOUR_PASSWORD@redis:6379/2

# Prometheus
PROMETHEUS_URL=http://prometheus:9090

# API Keys
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_API_KEY

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_NAME=SentinelAI
APP_VERSION=0.1.0
DEBUG=False
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# Celery
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=270

# LangGraph
LANGGRAPH_RECURSION_LIMIT=50
LANGGRAPH_TIMEOUT=300

# Vector Search
VECTOR_SEARCH_TOP_K=5
VECTOR_SEARCH_THRESHOLD=0.7
EMBEDDING_MODEL=text-embedding-ada-002

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
